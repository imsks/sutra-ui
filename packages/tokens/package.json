{
  "name": "@sutra/tokens",
  "version": "0.0.1",
  "description": "Framework-agnostic design tokens for the Sutra design system: TypeScript constants, CSS variables, and a Tailwind preset.",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist",
    "src/css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./tailwind": {
      "types": "./dist/tailwind/preset.d.ts",
      "import": "./dist/tailwind/preset.js",
      "require": "./dist/tailwind/preset.cjs"
    },
    "./css": "./src/css/variables.css"
  },
  "scripts": {
    "gen:css": "tsx src/scripts/generate-css.ts",
    "build": "tsx src/scripts/generate-css.ts && tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  }
}
